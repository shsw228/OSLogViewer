{
  "sourceLanguage" : "en",
  "strings" : {
    "`Logger(subsystem:category:)` with a `<area>.<topic>` category. The area becomes the top-level filter in the viewer." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "`Logger(subsystem:category:)` を `<area>.<topic>` 形式の category で作る。area がビューアの第1段フィルタになる。"
          }
        }
      }
    },
    "`OSLogExport.temporaryFile(subsystem:lookback:filter:)` collects recent logs into a .txt — pass a `LogFilter` to export only what you need (e.g. errors, or one area)." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "`OSLogExport.temporaryFile(subsystem:lookback:filter:)` で直近ログを .txt にまとめる。`LogFilter` を渡せば必要なログ（例: エラーのみ / 特定 area）だけ出力できる。"
          }
        }
      }
    },
    "`OSLogViewer(subsystem:)` reads this process's logs for the given subsystem." : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "`OSLogViewer(subsystem:)` は指定 subsystem の自プロセスログを読み出す。"
          }
        }
      }
    },
